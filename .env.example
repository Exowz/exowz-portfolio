# Resend API Key
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Contact form (Resend)
CONTACT_FROM="Portfolio Contact <no-reply@yourdomain.com>"
CONTACT_TO="you@yourdomain.com"
CONTACT_CONFIRM_FROM="Your Name <no-reply@yourdomain.com>"

# Portfolio assistant (Mistral + Redis rate limiting)
# MISTRAL_API_KEY is secret. Set it in Vercel, do not commit a real key.
MISTRAL_API_KEY=
MISTRAL_AGENT_ID="ag_019ec2f15b4571e2ba1dc8fc3132b66c"
# Reference only: this library is attached to the Mistral agent, not read by the app.
# MISTRAL_LIBRARY_ID="019ec330-db64-72df-98e5-7b3617b64f1e"

# Redis is used for production rate limiting.
# Upstash example: rediss://default:<password>@<host>:6379
REDIS_URL=
